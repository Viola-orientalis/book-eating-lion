              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser_runner\",\n  \"password\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "2-3. 내 정보 조회 (GET /api/auth/me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
