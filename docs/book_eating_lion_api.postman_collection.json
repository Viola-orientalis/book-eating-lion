{
  "info": {
    "name": "Book Eating Lion API",
    "description": "K8s 기반 도서 쇼핑몰 - 미로그인 / 로그인 시나리오 분리 테스트 컬렉션\n\n1. 미로그인 시나리오: 공개 API 정상 작동 및 미인증 접근 시 401 차단 검증\n2. 로그인 시나리오: 로그인 후 JWT 발급 -> 인증 필요 API(내정보, 장바구니) 정상 수행 검증",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "cartItemId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01. 미로그인 시나리오 (Public & Unauthenticated)",
      "item": [
        {
          "name": "1-1. 회원가입 (POST /api/auth/signup)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser_signup_demo\",\n  \"password\": \"1234\",\n  \"name\": \"홍길동\"\n}"
            }
          }
        },
        {
          "name": "1-2. 도서 목록 조회 (GET /api/books)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "books"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "1-3. 도서 키워드 검색 (?keyword=사자)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books?keyword=사자&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "books"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "사자"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "1-4. 도서 상세 조회 (GET /api/books/1)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "books",
                "1"
              ]
            }
          }
        },
        {
          "name": "1-5. 헬스체크 (GET /health)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "[검증] 미로그인 상태에서 내정보 접근 → 401 차단",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "[검증] 미로그인 상태에서 장바구니 접근 → 401 차단",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02. 로그인 시나리오 (Authenticated & JWT)",
      "item": [
        {
          "name": "2-1. 로그인 실행 (POST /api/auth/login) ★ JWT 저장",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "2-2. 내 정보 조회 (GET /api/auth/me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "2-3. 장바구니 담기 (POST /api/cart) ★ cartItemId 저장",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.cartItemId) {",
                  "  pm.collectionVariables.set('cartItemId', String(json.cartItemId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "2-4. 장바구니 조회 (GET /api/cart)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart"
              ]
            }
          }
        },
        {
          "name": "2-5. 수량 변경 (PUT /api/cart/{{cartItemId}})",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cart/{{cartItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "{{cartItemId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            }
          }
        },
        {
          "name": "2-6. 장바구니 삭제 (DELETE /api/cart/{{cartItemId}})",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cart/{{cartItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cart",
                "{{cartItemId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}